# ====================================================================
# Project Takeover — V7 signal system (set these in Vercel → Settings →
# Environment Variables). Never commit real values. These are used only by
# the serverless functions in /api — never exposed to the frontend.
# ====================================================================

# Shared secret TradingView must include in every alert payload.
# Use the SAME value in the Pine "Webhook secret" input.
TRADINGVIEW_WEBHOOK_SECRET=

# Telegram (server-side proof). The bot token stays server-side only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Set to 1 so the webhook sends Telegram alerts (server-side, even when the
# app is closed). Leave unset to disable server alerts.
TELEGRAM_SERVER_ALERTS=1

# --- Storage: choose ONE (Supabase preferred, Upstash alternative). ---
# If neither is set, storage is in-memory (ephemeral; fine to smoke-test,
# but signals won't survive cold starts).

# Supabase (preferred). Requires a "signals" table — see README.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (alternative).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
